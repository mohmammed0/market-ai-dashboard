# Runtime settings saved from the UI take precedence over these values.
# Keep secrets blank here unless you intentionally want environment fallbacks.

MARKET_AI_ENV=development
MARKET_AI_API_TITLE=Market AI Dashboard API
MARKET_AI_API_VERSION=0.1.0
MARKET_AI_HOST=127.0.0.1
MARKET_AI_PORT=8000
MARKET_AI_SERVER_ROLE=all
MARKET_AI_DATA_DIR=./data
# Local development defaults to SQLite. For PostgreSQL testing, override MARKET_AI_DATABASE_URL.
MARKET_AI_DATABASE_URL=sqlite:///data/market_ai.db
MARKET_AI_DB_AUTO_MIGRATE=1
MARKET_AI_DB_RUN_MIGRATIONS_ON_STARTUP=1
MARKET_AI_DB_LEGACY_BOOTSTRAP=1
MARKET_AI_POSTGRES_DB=market_ai
MARKET_AI_POSTGRES_USER=market_ai
MARKET_AI_POSTGRES_PASSWORD=
MARKET_AI_DB_POOL_SIZE=5
MARKET_AI_DB_MAX_OVERFLOW=10
MARKET_AI_DB_POOL_TIMEOUT_SECONDS=30
MARKET_AI_DB_POOL_RECYCLE_SECONDS=1800
MARKET_AI_DB_CONNECT_TIMEOUT_SECONDS=10
MARKET_AI_DB_STATEMENT_TIMEOUT_MS=30000
MARKET_AI_DB_LOCK_TIMEOUT_MS=10000
MARKET_AI_DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=60000
MARKET_AI_ANALYSIS_CONCURRENCY=2
MARKET_AI_LOG_LEVEL=INFO
MARKET_AI_LOG_FILE_MAX_BYTES=5242880
MARKET_AI_LOG_FILE_BACKUP_COUNT=5
MARKET_AI_LOG_EVENTS_ENABLED=1
MARKET_AI_ENABLE_SCHEDULER=1
MARKET_AI_SCHEDULER_RUNNER_ROLE=automation
MARKET_AI_EVENT_TRANSPORT=inmemory
MARKET_AI_EVENT_PERSIST_DEAD_LETTERS=1
MARKET_AI_NATS_URL=nats://127.0.0.1:4222
MARKET_AI_NATS_STREAM=MARKET_AI
MARKET_AI_NATS_SUBJECT_PREFIX=market_ai
MARKET_AI_BACKGROUND_JOB_MAX_ACTIVE_TOTAL=4
MARKET_AI_BACKGROUND_JOB_MAX_ACTIVE_PER_TYPE=2
MARKET_AI_BACKGROUND_JOB_STALE_PENDING_SECONDS=300
MARKET_AI_TRAINING_SUBPROCESS_ENABLED=1
MARKET_AI_TRAINING_JOB_MAX_ACTIVE=1
MARKET_AI_TRAINING_JOB_STALE_PENDING_SECONDS=300
MARKET_AI_TRAINING_RUNNER_PYTHON=
MARKET_AI_CONTINUOUS_LEARNING_RUNNER_PYTHON=
MARKET_AI_ENABLE_CONTINUOUS_LEARNING=1
MARKET_AI_CONTINUOUS_LEARNING_RUNNER_ROLE=automation
MARKET_AI_CONTINUOUS_LEARNING_CYCLE_SECONDS=1800
MARKET_AI_CONTINUOUS_LEARNING_HEARTBEAT_SECONDS=30
MARKET_AI_CONTINUOUS_LEARNING_STALE_SECONDS=180
MARKET_AI_CONTINUOUS_LEARNING_PAUSE_SECONDS=20
MARKET_AI_CONTINUOUS_LEARNING_MAX_CANDIDATES=6
MARKET_AI_CONTINUOUS_LEARNING_EVALUATION_SYMBOLS=6
MARKET_AI_CONTINUOUS_LEARNING_POLICY_LOOKBACK_DAYS=60
MARKET_AI_PUBLIC_WEB_ORIGIN=
MARKET_AI_PUBLIC_API_ORIGIN=
MARKET_AI_SERVER_NAME=
MARKET_AI_TRUSTED_HOSTS=
MARKET_AI_PROXY_HEADERS_ENABLED=0
MARKET_AI_FORWARDED_ALLOW_IPS=*

# --- AI Provider ---
MARKET_AI_PROVIDER=ollama           # ollama | openai | auto (try Ollama first, fall back to OpenAI)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
OLLAMA_ENABLED=1
OLLAMA_TIMEOUT_SECONDS=120

# --- OpenAI (optional, remote) ---
# OpenAI is optional — Ollama handles everything locally
OPENAI_ENABLED=0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

# --- Authentication (optional, for securing LLM endpoints) ---
# MARKET_AI_AUTH_ENABLED=0
# MARKET_AI_AUTH_SECRET_KEY=          # generate: openssl rand -hex 32
# MARKET_AI_AUTH_DEFAULT_USERNAME=admin
# MARKET_AI_AUTH_DEFAULT_PASSWORD=    # MUST set for production
# MARKET_AI_AUTH_TOKEN_EXPIRE_MINUTES=1440

MARKET_AI_BROKER_PROVIDER=none
MARKET_AI_BROKER_TRADING_MODE=cash
MARKET_AI_BROKER_ORDER_SUBMISSION_ENABLED=0
MARKET_AI_BROKER_LIVE_EXECUTION_ENABLED=0
MARKET_AI_ALPACA_ENABLED=0
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=1
ALPACA_URL_OVERRIDE=
MARKET_AI_ALPACA_ACCOUNT_REFRESH_SECONDS=15
MARKET_AI_PRIMARY_MARKET_DATA_PROVIDER=alpaca
MARKET_AI_FALLBACK_MARKET_DATA_PROVIDERS=polygon,tiingo,twelvedata,yahoo
MARKET_AI_MARKET_TIMEZONE=America/New_York
MARKET_AI_MARKET_SESSION_CLOSE_HOUR=16
MARKET_AI_MARKET_SESSION_CLOSE_MINUTE=0
MARKET_AI_MARKET_SESSION_CLOSE_BUFFER_MINUTES=20
ALPACA_MARKET_DATA_API_KEY=
ALPACA_MARKET_DATA_SECRET_KEY=
MARKET_AI_ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
MARKET_AI_ALPACA_MARKET_DATA_FEED=iex
POLYGON_API_KEY=
MARKET_AI_POLYGON_MARKET_DATA_BASE_URL=https://api.polygon.io
TIINGO_API_KEY=
MARKET_AI_TIINGO_MARKET_DATA_BASE_URL=https://api.tiingo.com
TWELVEDATA_API_KEY=
MARKET_AI_TWELVEDATA_MARKET_DATA_BASE_URL=https://api.twelvedata.com

MARKET_AI_AUTOMATION_DEFAULT_PRESET=ALL_US_EQUITIES
MARKET_AI_AUTOMATION_SYMBOL_LIMIT=40
MARKET_AI_MARKET_CYCLE_MINUTES=30
MARKET_AI_ALERT_CYCLE_MINUTES=15
MARKET_AI_BREADTH_CYCLE_MINUTES=20
MARKET_AI_NEWS_REFRESH_MINUTES=10
MARKET_AI_NEWS_REFRESH_PER_SYMBOL_LIMIT=5
MARKET_AI_RETRAIN_CYCLE_HOURS=24
MARKET_AI_ENABLE_AUTO_RETRAIN=0
MARKET_AI_ENABLE_AUTONOMOUS_CYCLE=0
MARKET_AI_AUTONOMOUS_CYCLE_HOURS=12
MARKET_AI_AUTONOMOUS_ANALYSIS_SYMBOL_LIMIT=12
MARKET_AI_AUTONOMOUS_TRAIN_SYMBOL_LIMIT=24
MARKET_AI_AUTONOMOUS_HISTORY_LOOKBACK_DAYS=45
MARKET_AI_AUTONOMOUS_INCLUDE_DL=1
MARKET_AI_AUTONOMOUS_REFRESH_UNIVERSE=1
MARKET_AI_DAILY_SUMMARY_HOUR_UTC=21
MARKET_AI_AUTO_TRADING_ENABLED=0
MARKET_AI_AUTO_TRADING_CYCLE_MINUTES=30
MARKET_AI_AUTO_TRADING_QUANTITY=1
MARKET_AI_AUTO_TRADING_UNIVERSE_PRESET=TOP_500_MARKET_CAP

MARKET_AI_RISK_DEFAULT_PORTFOLIO_VALUE=100000
MARKET_AI_RISK_MAX_TRADE_PCT=1.0
MARKET_AI_RISK_MAX_DAILY_LOSS_PCT=2.5
MARKET_AI_RISK_DEFAULT_STOP_PCT=3.0
MARKET_AI_RISK_DEFAULT_TARGET_PCT=6.0
MARKET_AI_ALERT_BREAKOUT_PCT=3.5
MARKET_AI_ALERT_UNUSUAL_MOVE_PCT=5.0
MARKET_AI_ALERT_VOLUME_SPIKE_MULTIPLIER=2.0
MARKET_AI_ALERT_CONFIDENCE_JUMP=15
MARKET_AI_ALERT_SYMBOL_LIMIT=30
MARKET_AI_BREADTH_SYMBOL_LIMIT=40
MARKET_AI_WATCHLIST_SYMBOL_LIMIT=24
MARKET_AI_MODEL_PROMOTION_MIN_F1=0.33
MARKET_AI_MODEL_PROMOTION_MIN_TEST_ACCURACY=0.42
MARKET_AI_MODEL_PROMOTION_MAX_DRAWDOWN_PCT=35
MARKET_AI_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
MARKET_AI_SAMPLE_SYMBOLS=AAPL,MSFT,NVDA,SPY
MARKET_AI_INDEX_SYMBOLS=^GSPC,^DJI,^IXIC,^RUT,^VIX
MARKET_AI_UNIVERSE_TTL_HOURS=24
# --- Redis (cache + optional Celery broker) ---
# Set MARKET_AI_REDIS_URL to activate Redis-backed cache (shared across processes).
# Leave empty for local in-memory cache (single-process, no coordination).
MARKET_AI_REDIS_URL=
MARKET_AI_REDIS_ENABLED=0
MARKET_AI_REDIS_CACHE_TTL_DEFAULT=300
MARKET_AI_REDIS_CONNECT_TIMEOUT=5
MARKET_AI_REDIS_SOCKET_TIMEOUT=5
MARKET_AI_SQLITE_BUSY_TIMEOUT_MS=5000
MARKET_AI_SQLITE_CACHE_SIZE_KB=20000

# --- MLflow (experiment tracking) ---
# Set MLFLOW_TRACKING_URI to activate MLflow live experiment tracking.
# Leave empty for local DB fallback (runtime_settings table).
MLFLOW_TRACKING_URI=
MARKET_AI_MLFLOW_EXPERIMENT_PREFIX=market_ai

# --- Prefect (heavy workflow orchestration) ---
# Set PREFECT_API_URL to activate Prefect for heavy workflows (strategy_evaluation, batch_inference).
# Leave empty for direct in-process execution.
PREFECT_API_URL=

# --- Celery (short recurring task dispatch) ---
# Set CELERY_BROKER_URL to activate Celery for short tasks (quote_snapshot, maintenance_reconcile).
# Requires Redis or RabbitMQ as broker. Leave empty for direct in-process execution.
# Start worker: celery -A backend.app.services.celery_app worker --loglevel=info
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

MARKET_AI_RUNTIME_CACHE_DIR=./data/runtime_cache

VITE_API_BASE_URL=/
VITE_PORT=5173
VITE_PREVIEW_PORT=4173
MARKET_AI_BACKEND_UPSTREAM=backend:8000
