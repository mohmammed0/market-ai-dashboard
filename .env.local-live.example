# Local live-stack environment.
# Use this file when running with docker-compose.services.yml.
# Copy to .env or source before starting the backend:
#   copy .env.local-live.example .env
#   .\venv\Scripts\python.exe -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000

MARKET_AI_ENV=development
MARKET_AI_SERVER_ROLE=all
MARKET_AI_HOST=127.0.0.1
MARKET_AI_PORT=8000

# --- PostgreSQL (via docker-compose.services.yml) ---
MARKET_AI_DATABASE_URL=postgresql+psycopg://market_ai:market_ai_dev@127.0.0.1:5432/market_ai
MARKET_AI_DB_AUTO_MIGRATE=1
MARKET_AI_DB_RUN_MIGRATIONS_ON_STARTUP=1
MARKET_AI_DB_LEGACY_BOOTSTRAP=0
MARKET_AI_DB_POOL_SIZE=5
MARKET_AI_DB_MAX_OVERFLOW=10
MARKET_AI_DB_POOL_RECYCLE_SECONDS=1800
MARKET_AI_DB_CONNECT_TIMEOUT_SECONDS=10

# --- Redis (via docker-compose.services.yml) ---
MARKET_AI_REDIS_URL=redis://127.0.0.1:6379/0
MARKET_AI_REDIS_ENABLED=1
MARKET_AI_REDIS_CACHE_TTL_DEFAULT=300

# --- MLflow (via docker-compose.services.yml) ---
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MARKET_AI_MLFLOW_EXPERIMENT_PREFIX=market_ai

# --- Celery (uses Redis as broker) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# --- Prefect (local server) ---
# Start locally: prefect server start
PREFECT_API_URL=http://127.0.0.1:4200/api

# --- Standard dev settings ---
MARKET_AI_LOG_LEVEL=INFO
MARKET_AI_ENABLE_SCHEDULER=1
MARKET_AI_SCHEDULER_RUNNER_ROLE=automation
MARKET_AI_ENABLE_CONTINUOUS_LEARNING=1
MARKET_AI_SAMPLE_SYMBOLS=AAPL,MSFT,NVDA,SPY
MARKET_AI_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
OPENAI_ENABLED=0
