MARKET_AI_AUTO_TRADING_ANALYSIS_LOOKBACK_DAYS=30
POLYGON_API_KEY=
MARKET_AI_POLYGON_MARKET_DATA_BASE_URL=https://api.polygon.io
TIINGO_API_KEY=
MARKET_AI_TIINGO_MARKET_DATA_BASE_URL=https://api.tiingo.com
TWELVEDATA_API_KEY=
MARKET_AI_TWELVEDATA_MARKET_DATA_BASE_URL=https://api.twelvedata.com

# --- Redis (cache + Celery broker) ---
MARKET_AI_REDIS_URL=redis://redis:6379/0
MARKET_AI_REDIS_ENABLED=1
MARKET_AI_REDIS_CACHE_TTL_DEFAULT=300
MARKET_AI_REDIS_CONNECT_TIMEOUT=5
MARKET_AI_REDIS_SOCKET_TIMEOUT=5
MARKET_AI_KNOWLEDGE_DEFAULT_LIMIT=20
MARKET_AI_KNOWLEDGE_MAX_LIMIT=100
MARKET_AI_KNOWLEDGE_VECTOR_ENABLED=0
MARKET_AI_KNOWLEDGE_VECTOR_MIN_SCORE=0.35
MARKET_AI_KNOWLEDGE_READ_RATE_LIMIT_PER_MIN=120
MARKET_AI_KNOWLEDGE_WRITE_RATE_LIMIT_PER_MIN=30
MARKET_AI_AI_RESEARCH_RATE_LIMIT_PER_MIN=45
MARKET_AI_RESEARCH_NOTIFY_TELEGRAM=0
MARKET_AI_SQLITE_BUSY_TIMEOUT_MS=5000
MARKET_AI_SQLITE_CACHE_SIZE_KB=20000

# --- MLflow (experiment tracking) ---
# Activate MLflow for live experiment tracking (strategy lab, model training).
# When configured and reachable, all experiment runs log to MLflow.
# When absent, runs are stored in the local runtime_settings table.
MLFLOW_TRACKING_URI=http://mlflow:5000
MARKET_AI_MLFLOW_EXPERIMENT_PREFIX=market_ai

# --- Prefect (heavy workflow orchestration) ---
# Activate Prefect for heavy workflows (strategy_evaluation, batch_inference).
# When configured and reachable, workflows are submitted to Prefect orchestrator.
# When absent, workflows run directly in-process (same result, less observability).
PREFECT_API_URL=http://prefect:4200/api

# --- Celery (short recurring task dispatch) ---
# Activate Celery for short recurring tasks (quote_snapshot, maintenance_reconcile).
# Requires a running worker: celery -A backend.app.services.celery_app worker --loglevel=info
# When absent, tasks run directly in-process via APScheduler.
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- OpenTelemetry (distributed tracing, optional) ---
# Set endpoint to your collector (OTLP HTTP): http://otel-collector:4318/v1/traces
MARKET_AI_OTEL_ENABLED=0
MARKET_AI_OTEL_SERVICE_NAME=market-ai-backend
MARKET_AI_OTEL_EXPORTER_OTLP_ENDPOINT=
MARKET_AI_OTEL_EXPORTER_OTLP_INSECURE=1
MARKET_AI_OTEL_CONSOLE_EXPORTER_ENABLED=0
MARKET_AI_OTEL_INSTRUMENT_REQUESTS_ENABLED=1

# --- NATS / Event backbone (optional during modular-monolith phase) ---
# Switch MARKET_AI_EVENT_TRANSPORT to nats after the server and dependency are live.
# Subjects are published under MARKET_AI_NATS_SUBJECT_PREFIX.<event_type>
# Example: market_ai.execution.order.submitted

OPENAI_ENABLED=0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=30
OLLAMA_ENABLED=1
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma2:2b
OLLAMA_TIMEOUT_SECONDS=300

VITE_API_BASE_URL=/
MARKET_AI_BACKEND_UPSTREAM=backend:8000

# --- Session Intelligence / Pre-open Readiness ---
MARKET_AI_AUTO_TRADING_MARKET_SESSION_INTELLIGENCE_ENABLED=1
MARKET_AI_AUTO_TRADING_PREOPEN_READINESS_ENABLED=1
MARKET_AI_AUTO_TRADING_PREOPEN_READINESS_START_MINUTES=60
MARKET_AI_AUTO_TRADING_PREOPEN_REFRESH_INTERVAL_SECONDS=60
MARKET_AI_AUTO_TRADING_PREMARKET_TRADING_ENABLED=0
MARKET_AI_AUTO_TRADING_QUEUED_FOR_OPEN_ENABLED=1
MARKET_AI_AUTO_TRADING_WAIT_FOR_OPEN_CONFIRMATION_ENABLED=1
MARKET_AI_AUTO_TRADING_CAPITAL_RESERVE_FOR_OPEN_PCT=25
MARKET_AI_AUTO_TRADING_MARKET_SESSION_EXTENDED_HOURS_ENABLED=1

# --- Kronos Intelligence Layer ---
MARKET_AI_AUTO_TRADING_KRONOS_ENABLED=0
MARKET_AI_AUTO_TRADING_KRONOS_MODEL_NAME=NeoQuasar/Kronos-mini
MARKET_AI_AUTO_TRADING_KRONOS_TOKENIZER_NAME=NeoQuasar/Kronos-Tokenizer-2k
MARKET_AI_AUTO_TRADING_KRONOS_DEVICE_PREFERENCE=auto
MARKET_AI_AUTO_TRADING_KRONOS_TIMEOUT_SECONDS=20
MARKET_AI_AUTO_TRADING_KRONOS_WARMUP_ENABLED=1
MARKET_AI_AUTO_TRADING_KRONOS_BATCH_PREOPEN_ENABLED=1
MARKET_AI_AUTO_TRADING_KRONOS_CACHE_TTL_SECONDS=600
MARKET_AI_AUTO_TRADING_KRONOS_WEIGHT=0.18
MARKET_AI_AUTO_TRADING_KRONOS_PREMARKET_WEIGHT=0.26
MARKET_AI_AUTO_TRADING_KRONOS_OPENING_WEIGHT=0.24
MARKET_AI_AUTO_TRADING_KRONOS_MAX_SYMBOLS_PER_BATCH=20
MARKET_AI_AUTO_TRADING_KRONOS_MIN_INPUT_QUALITY=0.55
MARKET_AI_AUTO_TRADING_KRONOS_PREDICTION_HORIZON=12
MARKET_AI_AUTO_TRADING_KRONOS_LOOKBACK_ROWS=280
MARKET_AI_AUTO_TRADING_KRONOS_INPUT_INTERVAL=5m
