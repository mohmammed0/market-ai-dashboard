# Production fallback values.
# UI-managed runtime settings are preferred and should be the normal way users add keys.
# Rotate any key that was previously exposed in a server-side `.env`.

MARKET_AI_ENV=production
MARKET_AI_LOG_LEVEL=INFO
MARKET_AI_FOCUSED_PRODUCT_MODE=1
MARKET_AI_LIGHTWEIGHT_EXPERIMENT_MODE=1
MARKET_AI_LIGHTWEIGHT_EXPERIMENT_INCLUDE_DL=1
MARKET_AI_LIGHTWEIGHT_EXPERIMENT_MAX_SYMBOLS=6
MARKET_AI_LIGHTWEIGHT_EXPERIMENT_NEWS_LIMIT=8
MARKET_AI_SIGNAL_REFRESH_MINUTES=5
MARKET_AI_SIGNAL_CACHE_TTL_SECONDS=300
MARKET_AI_SIGNAL_REFRESH_MAX_WORKERS=3
MARKET_AI_DEFAULT_ANALYSIS_LOOKBACK_DAYS=30
MARKET_AI_DEFAULT_TRAINING_LOOKBACK_DAYS=365
MARKET_AI_DEFAULT_TRACKED_SYMBOL_LIMIT=6
MARKET_AI_HOST=0.0.0.0
MARKET_AI_PORT=8000
MARKET_AI_BACKEND_PUBLISHED_PORT=8000
MARKET_AI_FRONTEND_PUBLISHED_PORT=4173
MARKET_AI_DATA_DIR=/app/data
MARKET_AI_POSTGRES_DB=market_ai
MARKET_AI_POSTGRES_USER=market_ai
MARKET_AI_POSTGRES_PASSWORD=change-me
MARKET_AI_DATABASE_URL=postgresql+psycopg://market_ai:change-me@db:5432/market_ai
MARKET_AI_DB_AUTO_MIGRATE=1
MARKET_AI_DB_RUN_MIGRATIONS_ON_STARTUP_API=1
MARKET_AI_DB_RUN_MIGRATIONS_ON_STARTUP_AUTOMATION=0
MARKET_AI_DB_LEGACY_BOOTSTRAP=0
MARKET_AI_DB_POOL_SIZE=2
MARKET_AI_DB_MAX_OVERFLOW=2
MARKET_AI_DB_POOL_TIMEOUT_SECONDS=30
MARKET_AI_DB_POOL_RECYCLE_SECONDS=1800
MARKET_AI_DB_CONNECT_TIMEOUT_SECONDS=10
MARKET_AI_DB_STATEMENT_TIMEOUT_MS=30000
MARKET_AI_DB_LOCK_TIMEOUT_MS=10000
MARKET_AI_DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=60000
MARKET_AI_BACKEND_WORKERS=2
MARKET_AI_ANALYSIS_CONCURRENCY=3
MARKET_AI_DB_MEMORY_LIMIT=1536M
MARKET_AI_DB_CPU_LIMIT=1.5
MARKET_AI_BACKEND_MEMORY_LIMIT=4G
MARKET_AI_BACKEND_CPU_LIMIT=3.0
MARKET_AI_AUTOMATION_MEMORY_LIMIT=5G
MARKET_AI_AUTOMATION_CPU_LIMIT=3.0
MARKET_AI_REDIS_MEMORY_LIMIT=512M
MARKET_AI_REDIS_CPU_LIMIT=0.5
MARKET_AI_FRONTEND_MEMORY_LIMIT=128M
MARKET_AI_FRONTEND_CPU_LIMIT=0.5
MARKET_AI_OLLAMA_MEMORY_LIMIT=5G
MARKET_AI_OLLAMA_CPU_LIMIT=2.0
OLLAMA_KEEP_ALIVE=24h
MARKET_AI_LOG_FILE_MAX_BYTES=5242880
MARKET_AI_LOG_FILE_BACKUP_COUNT=5
MARKET_AI_LOG_EVENTS_ENABLED=1
MARKET_AI_PUBLIC_WEB_ORIGIN=https://your-dashboard-host.example
MARKET_AI_PUBLIC_API_ORIGIN=https://your-dashboard-host.example
MARKET_AI_SERVER_NAME=your-dashboard-host.example
MARKET_AI_TRUSTED_HOSTS=your-dashboard-host.example,localhost,127.0.0.1,backend
MARKET_AI_PROXY_HEADERS_ENABLED=1
MARKET_AI_FORWARDED_ALLOW_IPS=*
MARKET_AI_ALLOWED_ORIGINS=https://your-dashboard-host.example

MARKET_AI_ENABLE_SCHEDULER=1
MARKET_AI_SCHEDULER_RUNNER_ROLE=automation
MARKET_AI_EVENT_TRANSPORT=inmemory
MARKET_AI_EVENT_PERSIST_DEAD_LETTERS=1
MARKET_AI_NATS_URL=nats://nats:4222
MARKET_AI_NATS_STREAM=MARKET_AI
MARKET_AI_NATS_SUBJECT_PREFIX=market_ai
MARKET_AI_SERVER_ROLE_API=api
MARKET_AI_SERVER_ROLE_AUTOMATION=automation
MARKET_AI_BACKGROUND_JOB_MAX_ACTIVE_TOTAL=4
MARKET_AI_BACKGROUND_JOB_MAX_ACTIVE_PER_TYPE=2
MARKET_AI_BACKGROUND_JOB_STALE_PENDING_SECONDS=300
MARKET_AI_TRAINING_SUBPROCESS_ENABLED=1
MARKET_AI_TRAINING_JOB_MAX_ACTIVE=1
MARKET_AI_TRAINING_JOB_STALE_PENDING_SECONDS=300
MARKET_AI_ENABLE_CONTINUOUS_LEARNING=0
MARKET_AI_CONTINUOUS_LEARNING_RUNNER_ROLE=automation
MARKET_AI_CONTINUOUS_LEARNING_CYCLE_SECONDS=1800
MARKET_AI_CONTINUOUS_LEARNING_HEARTBEAT_SECONDS=30
MARKET_AI_CONTINUOUS_LEARNING_STALE_SECONDS=180
MARKET_AI_CONTINUOUS_LEARNING_PAUSE_SECONDS=20
MARKET_AI_CONTINUOUS_LEARNING_MAX_CANDIDATES=6
MARKET_AI_CONTINUOUS_LEARNING_EVALUATION_SYMBOLS=6
MARKET_AI_CONTINUOUS_LEARNING_POLICY_LOOKBACK_DAYS=60
MARKET_AI_ENABLE_AUTO_RETRAIN=0
MARKET_AI_ENABLE_AUTONOMOUS_CYCLE=0
MARKET_AI_AUTONOMOUS_CYCLE_HOURS=12
MARKET_AI_AUTONOMOUS_ANALYSIS_SYMBOL_LIMIT=10
MARKET_AI_AUTONOMOUS_TRAIN_SYMBOL_LIMIT=12
MARKET_AI_AUTONOMOUS_HISTORY_LOOKBACK_DAYS=45
MARKET_AI_AUTONOMOUS_INCLUDE_DL=1
MARKET_AI_AUTONOMOUS_REFRESH_UNIVERSE=1
MARKET_AI_NEWS_REFRESH_MINUTES=5
MARKET_AI_NEWS_REFRESH_PER_SYMBOL_LIMIT=5

# To activate Alpaca paper trading set MARKET_AI_BROKER_PROVIDER=alpaca and
# MARKET_AI_ALPACA_ENABLED=1. Enter the API keys via the Settings UI (they are
# stored encrypted in the DB via runtime_settings — do NOT put real keys here).
# Leave MARKET_AI_BROKER_ORDER_SUBMISSION_ENABLED=0 and
# MARKET_AI_BROKER_LIVE_EXECUTION_ENABLED=0 until you have verified connectivity.
# To disable broker entirely set MARKET_AI_BROKER_PROVIDER=none.
MARKET_AI_BROKER_PROVIDER=alpaca
MARKET_AI_BROKER_TRADING_MODE=cash
MARKET_AI_ALPACA_ENABLED=1
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=1
MARKET_AI_BROKER_ORDER_SUBMISSION_ENABLED=0
MARKET_AI_BROKER_LIVE_EXECUTION_ENABLED=0
# Market data provider chain.
# Alpaca is the primary source; keys are shared with the broker above
# and are read from the DB at runtime (enter them via the Settings UI).
# MARKET_AI_ALPACA_MARKET_DATA_FEED: 'iex' (free) or 'sip' (paid).
# Yahoo Finance is always the final fallback — no credentials required.
MARKET_AI_PRIMARY_MARKET_DATA_PROVIDER=alpaca
MARKET_AI_FALLBACK_MARKET_DATA_PROVIDERS=yahoo
MARKET_AI_MARKET_TIMEZONE=America/New_York
MARKET_AI_MARKET_SESSION_CLOSE_HOUR=16
MARKET_AI_MARKET_SESSION_CLOSE_MINUTE=0
MARKET_AI_MARKET_SESSION_CLOSE_BUFFER_MINUTES=20
# Leave blank — keys are synced automatically from the DB at startup.
# Only set these directly if you are NOT using the Settings UI.
ALPACA_MARKET_DATA_API_KEY=
ALPACA_MARKET_DATA_SECRET_KEY=
MARKET_AI_ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
MARKET_AI_ALPACA_MARKET_DATA_FEED=iex
MARKET_AI_AUTO_TRADING_ENABLED=0
MARKET_AI_AUTO_TRADING_CYCLE_MINUTES=5
MARKET_AI_AUTO_TRADING_CYCLE_LEASE_SECONDS=390
MARKET_AI_AUTO_TRADING_QUANTITY=1
MARKET_AI_AUTO_TRADING_NOTIONAL_PER_TRADE=8000
MARKET_AI_AUTO_TRADING_DAILY_LOSS_AUTO_HALT=1
MARKET_AI_AUTO_TRADING_UNIVERSE_PRESET=FOCUSED_SAMPLE
MARKET_AI_AUTO_TRADING_ALLOW_ADD_TO_EXISTING_LONGS=1
MARKET_AI_AUTO_TRADING_ADD_LONG_MIN_CONFIDENCE=65
MARKET_AI_AUTO_TRADING_ADD_LONG_MIN_SCORE=0.20
MARKET_AI_AUTO_TRADING_ADD_LONG_MAX_POSITION_PCT=8.0
MARKET_AI_AUTO_TRADING_ADD_LONG_MAX_ADDS_PER_SYMBOL_PER_DAY=3
MARKET_AI_AUTO_TRADING_ADD_LONG_COOLDOWN_MINUTES=45
MARKET_AI_AUTO_TRADING_ADD_LONG_MIN_NOTIONAL=100
MARKET_AI_AUTO_TRADING_ADD_LONG_MIN_SHARES=1
MARKET_AI_AUTO_TRADING_PARTIAL_FUNDING_ENABLED=1
MARKET_AI_AUTO_TRADING_MIN_PARTIAL_FUNDING_NOTIONAL=150
MARKET_AI_AUTO_TRADING_MIN_PARTIAL_FUNDING_RATIO=0.30
MARKET_AI_AUTO_TRADING_PARTIAL_FUNDING_TOP_RANK_ONLY=0
MARKET_AI_AUTO_TRADING_EXECUTION_ORCHESTRATOR_ENABLED=1
MARKET_AI_AUTO_TRADING_EXECUTION_MAX_SUBMISSIONS_PER_CYCLE=6
MARKET_AI_AUTO_TRADING_EXECUTION_SUBMISSION_SPACING_SECONDS=2
MARKET_AI_AUTO_TRADING_EXECUTION_SYMBOL_COOLDOWN_SECONDS=90
MARKET_AI_AUTO_TRADING_EXECUTION_REQUIRE_RELEASE_BEFORE_ENTRIES=1
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_ENABLED=1
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_MAX_ATTEMPTS=2
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_INITIAL_BACKOFF_SECONDS=2
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_MAX_BACKOFF_SECONDS=20
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_BACKOFF_MULTIPLIER=2.0
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_JITTER_ENABLED=1
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_ALLOWED_FOR_BROKER_SUBMIT=1
MARKET_AI_AUTO_TRADING_EXECUTION_RETRY_ALLOWED_FOR_DEPENDENCY_WAIT=1
MARKET_AI_AUTO_TRADING_EXECUTION_RECONCILIATION_ENABLED=1
MARKET_AI_AUTO_TRADING_EXECUTION_RECONCILIATION_WINDOW_SECONDS=25
MARKET_AI_AUTO_TRADING_EXECUTION_RECONCILIATION_POLL_INTERVAL_SECONDS=3
MARKET_AI_AUTO_TRADING_EXECUTION_RECONCILIATION_MAX_POLLS=8
MARKET_AI_AUTO_TRADING_EXECUTION_RECONCILIATION_STOP_ON_TERMINAL=1
MARKET_AI_AUTO_TRADING_EXECUTION_RECONCILIATION_UPDATE_DEPENDENT_ACTIONS=1
MARKET_AI_AUTO_TRADING_DIAGNOSTICS_RETENTION_CYCLES=200
MARKET_AI_AUTO_TRADING_DIAGNOSTICS_RETENTION_DELETE_BATCH_SIZE=500
MARKET_AI_TRADER_PROFILE=strong
MARKET_AI_AUTO_TRADING_MIN_SIGNAL_CONFIDENCE=59
MARKET_AI_AUTO_TRADING_MIN_ENSEMBLE_SCORE=0.18
MARKET_AI_AUTO_TRADING_MIN_AGREEMENT=0.25
MARKET_AI_DECISION_ACTION_BUY_CONFIDENCE=75
MARKET_AI_DECISION_ACTION_ADD_CONFIDENCE=58
MARKET_AI_DECISION_ACTION_EXIT_CONFIDENCE=73
MARKET_AI_DECISION_ACTION_TRIM_CONFIDENCE=56
MARKET_AI_DECISION_ACTION_HOLD_CONFIDENCE=55
